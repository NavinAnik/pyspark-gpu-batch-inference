# Copy to .env and fill in your values
# cp .env.example .env

# Kaggle API (https://www.kaggle.com/settings -> Create New Token)
# Replace with your real Kaggle username (see Account section on that page) and API key
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Optional: Hugging Face (higher rate limits, faster downloads)
# HF_TOKEN=your_hf_token

# Optional: Spark / inference tuning (M4 Pro 24GB: 10g driver, 1024 arrow batch, 64 inference batch)
# SPARK_DRIVER_MEMORY=10g
# SPARK_EXECUTOR_MEMORY=10g
# ARROW_MAX_RECORDS_PER_BATCH=1024
# INFERENCE_BATCH_SIZE=64
# SPARK_MASTER=local[*]
